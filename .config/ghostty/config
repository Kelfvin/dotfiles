#------------------------------------------------------------
# MacOS
#------------------------------------------------------------
macos-titlebar-style = hidden
macos-icon           = xray
macos-option-as-alt  = true

#------------------------------------------------------------
# Theme
#------------------------------------------------------------
theme              = Catppuccin Frappe
window-padding-x   = 10
window-padding-y   = 10
background-opacity = 0.85
background-blur    = 40
cursor-style       = block
cursor-style-blink = false

#-----------------------------------------------------------
# Font
#------------------------------------------------------------
font-family  = JetBrainsMono Nerd Font Mono
font-family  = Maple Mono NF CN
font-size    = 14
font-thicken = true

#------------------------------------------------------------
# Shader
#------------------------------------------------------------
custom-shader = "shaders/cursor_warp.glsl"
custom-shader = "shaders/ripple_cursor.glsl"

#------------------------------------------------------------
# Shell-Integration 
#------------------------------------------------------------
shell-integration-features = no-cursor,sudo,title,ssh-env,ssh-terminfo

#------------------------------------------------------------
# Behaviour
#------------------------------------------------------------
mouse-hide-while-typing = true

#------------------------------------------------------------
# Link
#------------------------------------------------------------
cursor-click-to-move = true
link-url             = true

#------------------------------------------------------------
# Clipboard
#------------------------------------------------------------
clipboard-read                 = allow
clipboard-write                = allow
clipboard-paste-protection     = true
clipboard-trim-trailing-spaces = true

#------------------------------------------------------------
# Key-Bind
#------------------------------------------------------------
# command + s save file in neovim
keybind = super+s=text:\x1b:w\n

# Tmux command + number change tmux window
# unbind shortcuts in ghostty
keybind = cmd+digit_1=unbind
keybind = cmd+digit_2=unbind
keybind = cmd+digit_3=unbind
keybind = cmd+digit_4=unbind
keybind = cmd+digit_5=unbind
keybind = cmd+digit_6=unbind
keybind = cmd+digit_7=unbind
keybind = cmd+digit_8=unbind
keybind = cmd+digit_9=unbind

# set command+number to Tmux shortcuts
keybind = cmd+digit_1=text:\x00\x31
keybind = cmd+digit_2=text:\x00\x32
keybind = cmd+digit_3=text:\x00\x33
keybind = cmd+digit_4=text:\x00\x34
keybind = cmd+digit_5=text:\x00\x35
keybind = cmd+digit_6=text:\x00\x36
keybind = cmd+digit_7=text:\x00\x37
keybind = cmd+digit_8=text:\x00\x38
keybind = cmd+digit_9=text:\x00\x39
